    "aim_button": {
      "size":     100,
      "position": "left_middle",
      "opacity":   75
    },
    "crouch": {
      "size":      80,
      "position":  "right_middle"
    },
    "movement_joystick": {
      "size":     140,
      "position": "left_bottom"
    }
